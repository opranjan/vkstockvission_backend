# ----- Core -----
PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/stockmantra

# ----- Redis (BullMQ queues + rate limiter + OTP store) -----
# If sharing Redis with other apps, use a dedicated DB number (e.g. /1) AND
# set REDIS_KEY_PREFIX to something unique to this project.
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=stockmantra

# ----- SMTP (Hostinger) -----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=you@yourdomain.in
SMTP_PASS=your-smtp-password
COMPANY_NAME=ALDERLEAF STOCKMANTRA Pvt Ltd
COMPANY_EMAIL=support@alstockmantra.in
EMAIL_CC=ops@alstockmantra.in

# SMTP throughput knobs — keep maxConnections >= EMAIL_WORKER_CONCURRENCY.
SMTP_POOL_MAX=5
SMTP_RATE_PER_SEC=10

# ----- Cloudinary (file storage) -----
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# ----- Worker / queue -----
# Set to "false" if you run `npm run worker` as a separate process and want the
# API host to NOT also process jobs.
RUN_WORKER_IN_PROCESS=true
EMAIL_WORKER_CONCURRENCY=5

# ----- OTP -----
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
